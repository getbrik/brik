#!/usr/bin/env bash
# brik - Portable CI/CD pipeline CLI
# Provides local tooling for validation, diagnostics, and stage execution.
# Does NOT participate in the production CI/CD flow - shared libraries do that.
#
# Usage: brik <command> [options]
# Commands: validate, doctor, init, run, self-update, self-uninstall, version, help
# shellcheck disable=SC1091
set -euo pipefail

# ---------------------------------------------------------------------------
# Bootstrap: resolve BRIK_HOME from the real location of this script
# ---------------------------------------------------------------------------
_brik_resolve_home() {
    local source="${BASH_SOURCE[0]}"
    local dir=""
    local bin_dir=""

    while [[ -L "${source}" ]]; do
        dir="$(cd -P "$(dirname "${source}")" && pwd)"
        source="$(readlink "${source}")"
        [[ "${source}" != /* ]] && source="${dir}/${source}"
    done

    bin_dir="$(cd -P "$(dirname "${source}")" && pwd)"
    dirname "${bin_dir}"
}

if [[ -n "${BRIK_HOME:-}" ]]; then
    _brik_resolved="$(_brik_resolve_home)"
    if [[ "${BRIK_HOME}" != "${_brik_resolved}" ]]; then
        printf 'warning: BRIK_HOME overridden by environment (%s)\n' "${BRIK_HOME}" >&2
    fi
    unset _brik_resolved
else
    BRIK_HOME="$(_brik_resolve_home)"
fi
readonly BRIK_HOME

readonly BRIK_VERSION="0.2.0"
readonly BRIK_SCHEMA_VERSION="v1"
readonly BRIK_RUNTIME="bash"
readonly BRIK_REF="v${BRIK_VERSION}"

readonly DEFAULT_CONFIG="brik.yml"
readonly DEFAULT_SCHEMA="${BRIK_HOME}/schemas/config/v1/brik.schema.json"

# Exit codes
readonly EXIT_OK=0
readonly EXIT_INVALID=2
readonly EXIT_NOT_FOUND=7

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

brik_print() {
    printf '%s\n' "$1"
}

brik_error() {
    printf 'error: %s\n' "$1" >&2
}

brik_hint() {
    printf 'hint: %s\n' "$1" >&2
}

brik_usage_error() {
    brik_error "$1"
    brik_error "Run 'brik help' for usage."
    return "${EXIT_INVALID}"
}

brik_require_arg() {
    local opt="$1"
    local val="${2-}"
    if [[ -z "${val}" ]]; then
        brik_error "${opt} requires a value"
        return "${EXIT_INVALID}"
    fi
}

brik_require_file() {
    local path="$1"
    local label="${2:-file}"
    if [[ ! -f "${path}" ]]; then
        brik_error "${label} not found: ${path}"
        return "${EXIT_NOT_FOUND}"
    fi
}

brik_require_dir() {
    local path="$1"
    local label="${2:-directory}"
    if [[ ! -d "${path}" ]]; then
        brik_error "${label} not found: ${path}"
        return "${EXIT_NOT_FOUND}"
    fi
}

# Check that a required tool is available on PATH.
brik_require_tool() {
    local tool="$1"
    local hint="${2:-}"

    if ! command -v "${tool}" >/dev/null 2>&1; then
        brik_error "'${tool}' is required but not found on PATH."
        if [[ -n "${hint}" ]]; then
            brik_hint "${hint}"
        fi
        return "${EXIT_INVALID}"
    fi
}

brik_tool_version() {
    local tool="$1"
    local version="installed"

    if command -v "${tool}" >/dev/null 2>&1; then
        version="$("${tool}" --version 2>/dev/null | head -n 1)" || true
    fi

    printf '%s\n' "${version}"
}

# ---------------------------------------------------------------------------
# Command: version
# ---------------------------------------------------------------------------

_brik_detect_install_method() {
    if command -v brew >/dev/null 2>&1 && brew list brik >/dev/null 2>&1; then
        printf 'brew'
    elif [[ -d "${BRIK_HOME}/.git" ]]; then
        if [[ "${BRIK_HOME}" != "${HOME}/.brik" ]]; then
            printf 'source'
        else
            printf 'git'
        fi
    else
        printf 'unknown'
    fi
}

cmd_version() {
    local verbose=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --verbose) verbose=true; shift ;;
            *) brik_usage_error "unknown option: $1" || return "$?" ;;
        esac
    done

    brik_print "brik ${BRIK_VERSION}"
    brik_print "schema: ${BRIK_SCHEMA_VERSION}"
    brik_print "runtime: ${BRIK_RUNTIME}"

    if [[ "${verbose}" == true ]]; then
        brik_print "home: ${BRIK_HOME}"
        brik_print "install: $(_brik_detect_install_method)"
        local commit_sha=""
        commit_sha="$(git -C "${BRIK_HOME}" rev-parse --short HEAD 2>/dev/null || echo "unknown")"
        brik_print "commit: ${commit_sha}"
    fi
}

# ---------------------------------------------------------------------------
# Command: help
# ---------------------------------------------------------------------------
cmd_help() {
    cat <<EOF
brik ${BRIK_VERSION} - Portable CI/CD pipeline CLI

Usage:
  brik <command> [options]

Commands:
  validate       Validate brik.yml against the JSON Schema
  doctor         Check prerequisites (tools, stack detection)
  init           Scaffold brik.yml and platform bootstrap file
  run stage      Execute a single pipeline stage locally
  run pipeline   Execute the full pipeline locally
  self-update    Update brik to the latest version
  self-uninstall Remove brik from your system
  version        Print brik version information
  help           Print this help message

Options for validate:
  --config <path>   Path to brik.yml (default: brik.yml in current directory)
  --schema <path>   Path to JSON Schema file (default: bundled schema)

Options for doctor:
  --workspace <path>   Path to project directory (default: current directory)

Options for init:
  --stack <name>       Stack: node, java, python, rust, dotnet (auto-detected if omitted)
  --platform <name>    Platform: gitlab (default), github, jenkins
  --dir <path>         Target directory (default: current directory)
  --non-interactive    Skip prompts, fail if stack cannot be auto-detected

Options for run stage:
  --config <path>      Path to brik.yml (default: brik.yml in workspace)
  --workspace <path>   Path to project workspace (default: current directory)

Options for run pipeline:
  --config <path>         Path to brik.yml (default: brik.yml in workspace)
  --workspace <path>      Path to project workspace (default: current directory)
  --continue-on-error     Continue pipeline despite stage failure
  --with-release          Include the release stage
  --with-package          Include the package stage
  --with-deploy           Include deploy and notify stages

Options for self-update:
  --channel <name>        Update channel: stable (default), edge
  --version <tag>         Update to a specific version tag

Options for self-uninstall:
  --force                 Skip confirmation prompt

Options for version:
  --verbose               Show additional info (home, install method, commit)

Stages:
  init, release, build, quality, security, test, package, deploy, notify

Examples:
  brik validate
  brik validate --config path/to/brik.yml
  brik doctor
  brik doctor --workspace ./my-project
  brik init
  brik init --stack node --platform gitlab
  brik run stage build
  brik run stage quality --workspace ./my-project
  brik run pipeline
  brik run pipeline --with-package --continue-on-error
  brik self-update
  brik self-update --channel edge
  brik self-update --version v0.2.0
  brik version
  brik version --verbose
EOF
}

# ---------------------------------------------------------------------------
# Command: validate
# ---------------------------------------------------------------------------
cmd_validate() {
    local config_path="${DEFAULT_CONFIG}"
    local schema_path="${DEFAULT_SCHEMA}"
    local json_output=""
    local validation_output=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --config)
                brik_require_arg "--config" "${2-}" || return "$?"
                config_path="$2"
                shift 2
                ;;
            --schema)
                brik_require_arg "--schema" "${2-}" || return "$?"
                schema_path="$2"
                shift 2
                ;;
            *)
                brik_usage_error "unknown option: $1" || return "$?"
                ;;
        esac
    done

    brik_require_file "${config_path}" "config file" || return "$?"
    brik_require_file "${schema_path}" "schema file" || return "$?"

    brik_require_tool "yq" "Install yq (mikefarah/yq): https://github.com/mikefarah/yq" || return "${EXIT_INVALID}"
    brik_require_tool "check-jsonschema" "Install check-jsonschema: pip install check-jsonschema" || return "${EXIT_INVALID}"

    if ! json_output="$(yq -o json "${config_path}" 2>&1)"; then
        brik_error "failed to parse ${config_path} as YAML"
        printf '%s\n' "${json_output}" >&2
        return "${EXIT_INVALID}"
    fi

    if ! validation_output="$(printf '%s\n' "${json_output}" | check-jsonschema --schemafile "${schema_path}" - 2>&1)"; then
        brik_error "${config_path} is invalid"
        printf '%s\n' "${validation_output}" >&2
        return "${EXIT_INVALID}"
    fi

    brik_print "${config_path} is valid"
    return "${EXIT_OK}"
}

# ---------------------------------------------------------------------------
# Command: doctor
# ---------------------------------------------------------------------------

# Detect project stack from workspace files.
# Returns the detected stack name or "unknown".
_brik_detect_stack() {
    local workspace="${1:-.}"

    if [[ -f "${workspace}/package.json" ]]; then
        printf 'node'
    elif [[ -f "${workspace}/pom.xml" || -f "${workspace}/build.gradle" ]]; then
        printf 'java'
    elif [[ -f "${workspace}/requirements.txt" || -f "${workspace}/setup.py" || -f "${workspace}/pyproject.toml" ]]; then
        printf 'python'
    elif [[ -f "${workspace}/Cargo.toml" ]]; then
        printf 'rust'
    elif compgen -G "${workspace}"/*.csproj >/dev/null || compgen -G "${workspace}"/*.sln >/dev/null; then
        printf 'dotnet'
    else
        printf 'unknown'
    fi
}

cmd_doctor() {
    local workspace="."
    local passed=0
    local failed=0
    local warned=0
    local tool_name=""
    local tool_hint=""
    local tool_version=""
    local stack=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --workspace)
                brik_require_arg "--workspace" "${2-}" || return "$?"
                workspace="$2"
                shift 2
                ;;
            *)
                brik_usage_error "unknown option: $1" || return "$?"
                ;;
        esac
    done

    brik_require_dir "${workspace}" "workspace directory" || return "$?"

    brik_print "brik doctor - checking prerequisites"
    brik_print "======================================"
    brik_print ""

    if [[ "${BASH_VERSINFO[0]}" -ge 4 ]]; then
        brik_print "  [OK]      bash ${BASH_VERSION} (>= 4 required)"
        passed=$((passed + 1))
    else
        brik_print "  [MISSING] bash >= 4 (found ${BASH_VERSION})"
        failed=$((failed + 1))
    fi

    for tool_name in yq jq; do
        case "${tool_name}" in
            yq) tool_hint="https://github.com/mikefarah/yq" ;;
            jq) tool_hint="https://jqlang.github.io/jq/" ;;
            *) tool_hint="" ;;
        esac

        if command -v "${tool_name}" >/dev/null 2>&1; then
            tool_version="$(brik_tool_version "${tool_name}")"
            brik_print "  [OK]      ${tool_name} (${tool_version})"
            passed=$((passed + 1))
        else
            brik_print "  [MISSING] ${tool_name} - install from ${tool_hint}"
            failed=$((failed + 1))
        fi
    done

    if command -v check-jsonschema >/dev/null 2>&1; then
        brik_print "  [OK]      check-jsonschema"
        passed=$((passed + 1))
    else
        brik_print "  [WARNING] check-jsonschema not found (needed for 'brik validate')"
        warned=$((warned + 1))
    fi

    if command -v shellcheck >/dev/null 2>&1; then
        brik_print "  [OK]      shellcheck"
        passed=$((passed + 1))
    else
        brik_print "  [WARNING] shellcheck not found (recommended for development)"
        warned=$((warned + 1))
    fi

    brik_print ""
    stack="$(_brik_detect_stack "${workspace}")"

    if [[ "${stack}" != "unknown" ]]; then
        brik_print "  Detected stack: ${stack} (from ${workspace})"
        brik_print ""

        case "${stack}" in
            node)
                for tool_name in node npm; do
                    if command -v "${tool_name}" >/dev/null 2>&1; then
                        tool_version="$(brik_tool_version "${tool_name}")"
                        brik_print "  [OK]      ${tool_name} (${tool_version})"
                        passed=$((passed + 1))
                    else
                        brik_print "  [MISSING] ${tool_name}"
                        failed=$((failed + 1))
                    fi
                done
                ;;
            java)
                for tool_name in java mvn; do
                    if command -v "${tool_name}" >/dev/null 2>&1; then
                        tool_version="$(brik_tool_version "${tool_name}")"
                        brik_print "  [OK]      ${tool_name} (${tool_version})"
                        passed=$((passed + 1))
                    else
                        brik_print "  [MISSING] ${tool_name}"
                        failed=$((failed + 1))
                    fi
                done
                ;;
            python)
                for tool_name in python3 pip3; do
                    if command -v "${tool_name}" >/dev/null 2>&1; then
                        tool_version="$(brik_tool_version "${tool_name}")"
                        brik_print "  [OK]      ${tool_name} (${tool_version})"
                        passed=$((passed + 1))
                    else
                        brik_print "  [MISSING] ${tool_name}"
                        failed=$((failed + 1))
                    fi
                done
                ;;
            rust)
                for tool_name in rustc cargo; do
                    if command -v "${tool_name}" >/dev/null 2>&1; then
                        tool_version="$(brik_tool_version "${tool_name}")"
                        brik_print "  [OK]      ${tool_name} (${tool_version})"
                        passed=$((passed + 1))
                    else
                        brik_print "  [MISSING] ${tool_name}"
                        failed=$((failed + 1))
                    fi
                done
                ;;
            dotnet)
                if command -v dotnet >/dev/null 2>&1; then
                    tool_version="$(brik_tool_version dotnet)"
                    brik_print "  [OK]      dotnet (${tool_version})"
                    passed=$((passed + 1))
                else
                    brik_print "  [MISSING] dotnet"
                    failed=$((failed + 1))
                fi
                ;;
        esac
    else
        brik_print "  No stack detected in ${workspace}"
    fi

    brik_print ""
    brik_print "======================================"

    local summary="${passed} checks passed"
    if [[ "${failed}" -gt 0 ]]; then
        summary="${summary}, ${failed} missing"
    fi
    if [[ "${warned}" -gt 0 ]]; then
        summary="${summary}, ${warned} warnings"
    fi
    brik_print "${summary}"

    if [[ "${failed}" -gt 0 ]]; then
        return "${EXIT_INVALID}"
    fi

    return "${EXIT_OK}"
}

# ---------------------------------------------------------------------------
# Command: init
# ---------------------------------------------------------------------------
cmd_init() {
    local stack=""
    local platform="gitlab"
    local target_dir="."
    local non_interactive=false
    local project_name=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stack)
                brik_require_arg "--stack" "${2-}" || return "$?"
                stack="$2"
                shift 2
                ;;
            --platform)
                brik_require_arg "--platform" "${2-}" || return "$?"
                platform="$2"
                shift 2
                ;;
            --dir)
                brik_require_arg "--dir" "${2-}" || return "$?"
                target_dir="$2"
                shift 2
                ;;
            --non-interactive)
                non_interactive=true
                shift
                ;;
            *)
                brik_usage_error "unknown option: $1" || return "$?"
                ;;
        esac
    done

    brik_require_dir "${target_dir}" "target directory" || return "$?"

    if [[ -f "${target_dir}/brik.yml" ]]; then
        brik_error "brik.yml already exists in ${target_dir}"
        return "${EXIT_INVALID}"
    fi

    if [[ -z "${stack}" ]]; then
        stack="$(_brik_detect_stack "${target_dir}")"
        if [[ "${stack}" == "unknown" ]]; then
            if [[ "${non_interactive}" == true ]]; then
                brik_error "could not detect stack and --stack was not specified"
                return "${EXIT_INVALID}"
            fi
            brik_error "could not detect stack - use --stack to specify one"
            return "${EXIT_INVALID}"
        fi
        brik_print "Detected stack: ${stack}"
    fi

    case "${stack}" in
        node|java|python|rust|dotnet) ;;
        *)
            brik_error "unsupported stack: ${stack}"
            brik_error "Supported stacks: node, java, python, rust, dotnet"
            return "${EXIT_INVALID}"
            ;;
    esac

    case "${platform}" in
        gitlab|github|jenkins) ;;
        *)
            brik_error "unsupported platform: ${platform}"
            brik_error "Supported platforms: gitlab, github, jenkins"
            return "${EXIT_INVALID}"
            ;;
    esac

    project_name="$(basename "$(cd "${target_dir}" && pwd)")"

    _brik_generate_config "${target_dir}" "${project_name}" "${stack}"
    _brik_generate_bootstrap "${target_dir}" "${platform}"

    brik_print "Created brik.yml and ${platform} bootstrap in ${target_dir}"
    return "${EXIT_OK}"
}

_brik_generate_config() {
    local target_dir="$1"
    local project_name="$2"
    local stack="$3"

    cat > "${target_dir}/brik.yml" <<YAML
version: 1

project:
  name: "${project_name}"
  stack: ${stack}
YAML
}

_brik_generate_bootstrap() {
    local target_dir="$1"
    local platform="$2"

    case "${platform}" in
        gitlab)
            cat > "${target_dir}/.gitlab-ci.yml" <<YAML
include:
  - project: 'brik/gitlab-templates'
    ref: ${BRIK_REF}
    file: '/templates/pipeline.yml'
YAML
            ;;
        github)
            mkdir -p "${target_dir}/.github/workflows"
            cat > "${target_dir}/.github/workflows/ci.yml" <<YAML
name: Brik Pipeline
on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  brik:
    uses: getbrik/brik/.github/workflows/brik-pipeline.yml@${BRIK_REF}
    with:
      config: brik.yml
YAML
            ;;
        jenkins)
            cat > "${target_dir}/Jenkinsfile" <<GROOVY
@Library('brik@${BRIK_REF}') _
brikPipeline()
GROOVY
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Command: self-update
# ---------------------------------------------------------------------------

cmd_self_update() {
    local channel="stable"
    local target_version=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --channel)
                brik_require_arg "--channel" "${2-}" || return "$?"
                channel="$2"
                shift 2
                ;;
            --version)
                brik_require_arg "--version" "${2-}" || return "$?"
                target_version="$2"
                shift 2
                ;;
            *)
                brik_usage_error "unknown option: $1" || return "$?"
                ;;
        esac
    done

    case "${channel}" in
        stable|edge) ;;
        *)
            brik_error "invalid channel: ${channel}"
            brik_error "Supported channels: stable, edge"
            return "${EXIT_INVALID}"
            ;;
    esac

    # Detect installation method
    local method=""
    method="$(_brik_detect_install_method)"

    case "${method}" in
        git)
            _brik_self_update_git "${channel}" "${target_version}"
            ;;
        brew)
            brik_print "updating via Homebrew..."
            brew upgrade getbrik/tap/brik
            ;;
        *)
            brik_error "cannot self-update: unknown installation method"
            brik_error "reinstall with: curl -fsSL https://raw.githubusercontent.com/getbrik/brik/main/scripts/install.sh | bash"
            return "${EXIT_INVALID}"
            ;;
    esac

    brik_print ""
    brik_print "update complete"
    local new_version=""
    new_version="$("${BRIK_HOME}/bin/brik" version 2>/dev/null | head -n 1)" || true
    if [[ -n "${new_version}" ]]; then
        brik_print "${new_version}"
    fi
}

_brik_self_update_git() {
    local channel="$1"
    local target_version="$2"

    if [[ ! -d "${BRIK_HOME}/.git" ]]; then
        brik_error "not a git installation: ${BRIK_HOME}"
        return "${EXIT_INVALID}"
    fi

    # Warn if working tree is dirty
    if [[ -n "$(git -C "${BRIK_HOME}" status --porcelain 2>/dev/null)" ]]; then
        brik_error "working tree is dirty in ${BRIK_HOME}"
        brik_hint "do not modify files in ${BRIK_HOME} manually"
        return "${EXIT_INVALID}"
    fi

    local git_output=""

    brik_print "fetching updates..."
    if ! git_output="$(git -C "${BRIK_HOME}" fetch --tags origin 2>&1)"; then
        brik_error "failed to fetch from remote"
        printf '%s\n' "${git_output}" >&2
        return "${EXIT_INVALID}"
    fi

    if [[ -n "${target_version}" ]]; then
        brik_print "switching to ${target_version}..."
        if ! git_output="$(git -C "${BRIK_HOME}" checkout "${target_version}" 2>&1)"; then
            brik_error "version ${target_version} not found"
            printf '%s\n' "${git_output}" >&2
            return "${EXIT_INVALID}"
        fi
    elif [[ "${channel}" == "edge" ]]; then
        brik_print "switching to edge (main branch)..."
        git -C "${BRIK_HOME}" checkout main 2>/dev/null || true
        if ! git_output="$(git -C "${BRIK_HOME}" pull --ff-only origin main 2>&1)"; then
            brik_error "failed to pull latest changes"
            printf '%s\n' "${git_output}" >&2
            return "${EXIT_INVALID}"
        fi
    else
        # stable: checkout latest tag
        local latest=""
        latest="$(git -C "${BRIK_HOME}" describe --tags --abbrev=0 origin/main 2>/dev/null)" || true
        if [[ -z "${latest}" ]]; then
            brik_error "no tags found - try: brik self-update --channel edge"
            return "${EXIT_INVALID}"
        fi
        brik_print "switching to ${latest}..."
        if ! git_output="$(git -C "${BRIK_HOME}" checkout "${latest}" 2>&1)"; then
            brik_error "failed to checkout ${latest}"
            printf '%s\n' "${git_output}" >&2
            return "${EXIT_INVALID}"
        fi
    fi
}

# ---------------------------------------------------------------------------
# Command: self-uninstall
# ---------------------------------------------------------------------------

cmd_self_uninstall() {
    local force=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force) force=true; shift ;;
            *) brik_usage_error "unknown option: $1" || return "$?" ;;
        esac
    done

    if [[ "${force}" != true ]]; then
        printf 'Are you sure? This will remove Brik from your system. [y/N] '
        local answer=""
        read -r answer
        case "${answer}" in
            y|Y|yes|YES) ;;
            *)
                brik_print "cancelled"
                return "${EXIT_OK}"
                ;;
        esac
    fi

    # Remove shim or symlink from known locations
    for candidate in "/usr/local/bin/brik" "${HOME}/.local/bin/brik"; do
        if [[ -f "${candidate}" || -L "${candidate}" ]]; then
            brik_print "removing: ${candidate}"
            rm -f "${candidate}" 2>/dev/null || {
                brik_error "failed to remove ${candidate} - try with sudo"
            }
        fi
    done

    # Validate before deleting runtime
    local home_to_remove="${BRIK_HOME}"
    if [[ -z "${home_to_remove}" || "${home_to_remove}" == "/" ]]; then
        brik_error "refusing to remove suspicious path: ${home_to_remove}"
        return "${EXIT_INVALID}"
    fi
    if [[ ! -f "${home_to_remove}/bin/brik" ]]; then
        brik_error "path does not look like a brik installation: ${home_to_remove}"
        return "${EXIT_INVALID}"
    fi

    brik_print "removing runtime: ${home_to_remove}"
    rm -rf "${home_to_remove}"
    brik_print ""
    brik_print "brik has been removed"
}

# ---------------------------------------------------------------------------
# Command: run
# ---------------------------------------------------------------------------
cmd_run() {
    if [[ $# -eq 0 ]]; then
        brik_error "'brik run' requires a subcommand. Usage: brik run {stage|pipeline}"
        return "${EXIT_INVALID}"
    fi

    local subcmd="$1"
    shift

    case "${subcmd}" in
        stage)    cmd_run_stage "$@" ;;
        pipeline) cmd_run_pipeline "$@" ;;
        *)
            brik_usage_error "unknown run subcommand: ${subcmd}" || return "$?"
            ;;
    esac
}

# Source the local wrapper and run setup.
# Accepts optional overrides for workspace and config via environment.
_setup_local_env() {
    local wrapper="${BRIK_HOME}/shared-libs/local/scripts/local-wrapper.sh"
    brik_require_file "${wrapper}" "local wrapper" || return "$?"
    # shellcheck source=../shared-libs/local/scripts/local-wrapper.sh
    . "${wrapper}"

    local rc
    set +e
    brik.local.setup
    rc=$?
    set -e
    return "$rc"
}

# Run a command with set -e disabled; return its exit code.
_brik_run_runtime() {
    local rc
    set +e
    "$@"
    rc=$?
    set -e
    return "$rc"
}

cmd_run_stage() {
    local stage_name=""
    local config_path=""
    local workspace=""

    if [[ $# -eq 0 ]]; then
        brik_error "'brik run stage' requires a stage name"
        return "${EXIT_INVALID}"
    fi

    stage_name="$1"
    shift
    workspace="$(pwd)"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --config)
                brik_require_arg "--config" "${2-}" || return "$?"
                config_path="$2"
                shift 2
                ;;
            --workspace)
                brik_require_arg "--workspace" "${2-}" || return "$?"
                workspace="$2"
                shift 2
                ;;
            *)
                brik_usage_error "unknown option: $1" || return "$?"
                ;;
        esac
    done

    # Default config path: look in workspace directory
    if [[ -z "$config_path" ]]; then
        config_path="${workspace}/${DEFAULT_CONFIG}"
    fi

    # Export environment for the local wrapper
    export BRIK_PROJECT_DIR="${workspace}"
    export BRIK_WORKSPACE="${workspace}"
    export BRIK_CONFIG_FILE="${config_path}"
    export BRIK_LOG_DIR="${BRIK_LOG_DIR:-/tmp/brik/logs}"
    mkdir -p "${BRIK_LOG_DIR}"

    _setup_local_env || return "$?"

    _brik_run_runtime brik.local.run_stage "$stage_name"
}

cmd_run_pipeline() {
    local config_path=""
    local workspace=""
    local -a pipeline_flags=()

    workspace="$(pwd)"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --config)
                brik_require_arg "--config" "${2-}" || return "$?"
                config_path="$2"
                shift 2
                ;;
            --workspace)
                brik_require_arg "--workspace" "${2-}" || return "$?"
                workspace="$2"
                shift 2
                ;;
            --continue-on-error|--with-release|--with-package|--with-deploy)
                pipeline_flags+=("$1")
                shift
                ;;
            *)
                brik_usage_error "unknown option: $1" || return "$?"
                ;;
        esac
    done

    # Default config path: look in workspace directory
    if [[ -z "$config_path" ]]; then
        config_path="${workspace}/${DEFAULT_CONFIG}"
    fi

    # Export environment for the local wrapper
    export BRIK_PROJECT_DIR="${workspace}"
    export BRIK_WORKSPACE="${workspace}"
    export BRIK_CONFIG_FILE="${config_path}"
    export BRIK_LOG_DIR="${BRIK_LOG_DIR:-/tmp/brik/logs}"
    mkdir -p "${BRIK_LOG_DIR}"

    _setup_local_env || return "$?"

    _brik_run_runtime brik.local.run_pipeline "${pipeline_flags[@]}"
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------
main() {
    local command=""

    if [[ $# -eq 0 ]]; then
        cmd_help
        exit "${EXIT_OK}"
    fi

    command="$1"
    shift

    case "${command}" in
        validate)
            cmd_validate "$@"
            exit "$?"
            ;;
        doctor)
            cmd_doctor "$@"
            exit "$?"
            ;;
        init)
            cmd_init "$@"
            exit "$?"
            ;;
        run)
            cmd_run "$@"
            exit "$?"
            ;;
        self-update)
            cmd_self_update "$@"
            exit "$?"
            ;;
        self-uninstall)
            cmd_self_uninstall "$@"
            exit "$?"
            ;;
        version)
            cmd_version "$@"
            exit "$?"
            ;;
        help|--help|-h)
            cmd_help
            exit "${EXIT_OK}"
            ;;
        *)
            brik_usage_error "unknown command: ${command}" || exit "$?"
            ;;
    esac
}

main "$@"
