#!/usr/bin/env bash
# brik - Portable CI/CD pipeline CLI
# Provides local tooling for validation, diagnostics, and stage execution.
# Does NOT participate in the production CI/CD flow - shared libraries do that.
#
# Usage: brik <command> [options]
# Commands: validate, doctor, init, run, version, help
# shellcheck disable=SC1091,SC2317
set -euo pipefail

# ---------------------------------------------------------------------------
# Bootstrap: resolve BRIK_HOME from the real location of this script
# ---------------------------------------------------------------------------
_brik_resolve_home() {
    local source="${BASH_SOURCE[0]}"
    while [[ -L "${source}" ]]; do
        local dir
        dir="$(cd -P "$(dirname "${source}")" && pwd)"
        source="$(readlink "${source}")"
        [[ "${source}" != /* ]] && source="${dir}/${source}"
    done
    local bin_dir
    bin_dir="$(cd -P "$(dirname "${source}")" && pwd)"
    dirname "${bin_dir}"
}

if [[ -n "${BRIK_HOME:-}" ]]; then
    _brik_resolved="$(_brik_resolve_home)"
    if [[ "${BRIK_HOME}" != "${_brik_resolved}" ]]; then
        printf 'warning: BRIK_HOME overridden by environment (%s)\n' "${BRIK_HOME}" >&2
    fi
    unset _brik_resolved
else
    BRIK_HOME="$(_brik_resolve_home)"
fi
readonly BRIK_HOME

BRIK_VERSION="0.1.0"
BRIK_SCHEMA_VERSION="v1"
BRIK_RUNTIME="bash"

readonly BRIK_VERSION BRIK_SCHEMA_VERSION BRIK_RUNTIME

readonly DEFAULT_CONFIG="brik.yml"
readonly DEFAULT_SCHEMA="${BRIK_HOME}/schemas/config/v1/brik.schema.json"

# Exit codes
readonly EXIT_OK=0
readonly EXIT_INVALID=2
readonly EXIT_NOT_FOUND=7

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

# Print a message to stdout
brik_print() {
    printf '%s\n' "$*"
}

# Print a message to stderr
brik_error() {
    printf 'error: %s\n' "$*" >&2
}

# Check that a required tool is available on PATH.
# Prints a helpful message and returns 1 if the tool is missing.
brik_require_tool() {
    local tool="$1"
    local hint="${2:-}"
    if ! command -v "${tool}" >/dev/null 2>&1; then
        brik_error "'${tool}' is required but not found on PATH."
        if [[ -n "${hint}" ]]; then
            printf 'hint: %s\n' "${hint}" >&2
        fi
        return 1
    fi
}

# ---------------------------------------------------------------------------
# Command: version
# ---------------------------------------------------------------------------
cmd_version() {
    brik_print "brik ${BRIK_VERSION}"
    brik_print "schema: ${BRIK_SCHEMA_VERSION}"
    brik_print "runtime: ${BRIK_RUNTIME}"
}

# ---------------------------------------------------------------------------
# Command: help
# ---------------------------------------------------------------------------
cmd_help() {
    cat <<EOF
brik ${BRIK_VERSION} - Portable CI/CD pipeline CLI

Usage:
  brik <command> [options]

Commands:
  validate    Validate brik.yml against the JSON Schema
  doctor      Check prerequisites (tools, stack detection)
  init        Scaffold brik.yml and platform bootstrap file
  run stage   Execute a pipeline stage locally
  version     Print brik version information
  help        Print this help message

Options for validate:
  --config <path>   Path to brik.yml (default: brik.yml in current directory)
  --schema <path>   Path to JSON Schema file (default: bundled schema)

Options for doctor:
  --workspace <path>   Path to project directory (default: current directory)

Options for init:
  --stack <name>       Stack: node, java, python, rust, dotnet (auto-detected if omitted)
  --platform <name>    Platform: gitlab (default), github, jenkins
  --dir <path>         Target directory (default: current directory)
  --non-interactive    Skip prompts, fail if stack cannot be auto-detected

Options for run stage:
  --config <path>      Path to brik.yml (default: brik.yml in current directory)
  --workspace <path>   Path to project workspace (default: current directory)

Examples:
  brik validate
  brik validate --config path/to/brik.yml
  brik doctor
  brik doctor --workspace ./my-project
  brik init
  brik init --stack node --platform gitlab
  brik run stage build
  brik run stage test --workspace ./my-project
  brik version
EOF
}

# ---------------------------------------------------------------------------
# Command: validate
# ---------------------------------------------------------------------------
cmd_validate() {
    local config_path="${DEFAULT_CONFIG}"
    local schema_path="${DEFAULT_SCHEMA}"

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --config)
                if [[ $# -lt 2 || -z "$2" ]]; then
                    brik_error "--config requires a path argument"
                    return "${EXIT_INVALID}"
                fi
                config_path="$2"
                shift 2
                ;;
            --schema)
                if [[ $# -lt 2 || -z "$2" ]]; then
                    brik_error "--schema requires a path argument"
                    return "${EXIT_INVALID}"
                fi
                schema_path="$2"
                shift 2
                ;;
            *)
                brik_error "unknown option: $1"
                brik_error "Run 'brik help' for usage."
                return "${EXIT_INVALID}"
                ;;
        esac
    done

    # Verify config file exists
    if [[ ! -f "${config_path}" ]]; then
        brik_error "config file not found: ${config_path}"
        return "${EXIT_NOT_FOUND}"
    fi

    # Verify schema file exists
    if [[ ! -f "${schema_path}" ]]; then
        brik_error "schema file not found: ${schema_path}"
        return "${EXIT_NOT_FOUND}"
    fi

    # Check required tools
    brik_require_tool "yq" "Install yq (mikefarah/yq): https://github.com/mikefarah/yq" || return "${EXIT_INVALID}"
    brik_require_tool "check-jsonschema" "Install check-jsonschema: pip install check-jsonschema" || return "${EXIT_INVALID}"

    # Step 1: convert YAML to JSON
    local json_output
    if ! json_output="$(yq -o json "${config_path}" 2>&1)"; then
        brik_error "failed to parse ${config_path} as YAML"
        printf '%s\n' "${json_output}" >&2
        return "${EXIT_INVALID}"
    fi

    # Step 2: validate JSON against schema
    local validation_output
    if ! validation_output="$(printf '%s\n' "${json_output}" | check-jsonschema --schemafile "${schema_path}" - 2>&1)"; then
        brik_error "${config_path} is invalid"
        printf '%s\n' "${validation_output}" >&2
        return "${EXIT_INVALID}"
    fi

    brik_print "${config_path} is valid"
    return "${EXIT_OK}"
}

# ---------------------------------------------------------------------------
# Command: doctor
# ---------------------------------------------------------------------------

# Detect project stack from workspace files.
# Returns the detected stack name or "unknown".
_brik_detect_stack() {
    local workspace="${1:-.}"
    if [[ -f "${workspace}/package.json" ]]; then
        printf 'node'
    elif [[ -f "${workspace}/pom.xml" ]] || [[ -f "${workspace}/build.gradle" ]]; then
        printf 'java'
    elif [[ -f "${workspace}/requirements.txt" ]] || [[ -f "${workspace}/setup.py" ]] || [[ -f "${workspace}/pyproject.toml" ]]; then
        printf 'python'
    elif [[ -f "${workspace}/Cargo.toml" ]]; then
        printf 'rust'
    elif [[ -f "${workspace}/${workspace}".csproj ]] || ls "${workspace}"/*.csproj >/dev/null 2>&1 || [[ -f "${workspace}/${workspace}".sln ]] || ls "${workspace}"/*.sln >/dev/null 2>&1; then
        printf 'dotnet'
    else
        printf 'unknown'
    fi
}

cmd_doctor() {
    local workspace="."
    local passed=0
    local failed=0
    local warned=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --workspace) workspace="$2"; shift 2 ;;
            *) brik_error "unknown option: $1"; return "${EXIT_INVALID}" ;;
        esac
    done

    brik_print "brik doctor - checking prerequisites"
    brik_print "======================================"
    brik_print ""

    # Check bash version
    local bash_major="${BASH_VERSINFO[0]}"
    if [[ "${bash_major}" -ge 4 ]]; then
        brik_print "  [OK]      bash ${BASH_VERSION} (>= 4 required)"
        passed=$((passed + 1))
    else
        brik_print "  [MISSING] bash >= 4 (found ${BASH_VERSION})"
        failed=$((failed + 1))
    fi

    # Check core tools
    local tool_name tool_hint
    for tool_name in yq jq; do
        case "${tool_name}" in
            yq) tool_hint="https://github.com/mikefarah/yq" ;;
            jq) tool_hint="https://jqlang.github.io/jq/" ;;
        esac
        if command -v "${tool_name}" >/dev/null 2>&1; then
            local tool_version
            tool_version="$("${tool_name}" --version 2>/dev/null | head -1)" || tool_version="installed"
            brik_print "  [OK]      ${tool_name} (${tool_version})"
            passed=$((passed + 1))
        else
            brik_print "  [MISSING] ${tool_name} - install from ${tool_hint}"
            failed=$((failed + 1))
        fi
    done

    # Check optional tools
    if command -v check-jsonschema >/dev/null 2>&1; then
        brik_print "  [OK]      check-jsonschema"
        passed=$((passed + 1))
    else
        brik_print "  [WARNING] check-jsonschema not found (needed for 'brik validate')"
        warned=$((warned + 1))
    fi

    if command -v shellcheck >/dev/null 2>&1; then
        brik_print "  [OK]      shellcheck"
        passed=$((passed + 1))
    else
        brik_print "  [WARNING] shellcheck not found (recommended for development)"
        warned=$((warned + 1))
    fi

    # Detect stack and check stack-specific tools
    brik_print ""
    local stack
    stack="$(_brik_detect_stack "${workspace}")"
    if [[ "${stack}" != "unknown" ]]; then
        brik_print "  Detected stack: ${stack} (from ${workspace})"
        brik_print ""
        case "${stack}" in
            node)
                for tool_name in node npm; do
                    if command -v "${tool_name}" >/dev/null 2>&1; then
                        local ver
                        ver="$("${tool_name}" --version 2>/dev/null | head -1)"
                        brik_print "  [OK]      ${tool_name} (${ver})"
                        passed=$((passed + 1))
                    else
                        brik_print "  [MISSING] ${tool_name}"
                        failed=$((failed + 1))
                    fi
                done
                ;;
            java)
                for tool_name in java mvn; do
                    if command -v "${tool_name}" >/dev/null 2>&1; then
                        brik_print "  [OK]      ${tool_name}"
                        passed=$((passed + 1))
                    else
                        brik_print "  [MISSING] ${tool_name}"
                        failed=$((failed + 1))
                    fi
                done
                ;;
            python)
                for tool_name in python3 pip3; do
                    if command -v "${tool_name}" >/dev/null 2>&1; then
                        brik_print "  [OK]      ${tool_name}"
                        passed=$((passed + 1))
                    else
                        brik_print "  [MISSING] ${tool_name}"
                        failed=$((failed + 1))
                    fi
                done
                ;;
            rust)
                for tool_name in rustc cargo; do
                    if command -v "${tool_name}" >/dev/null 2>&1; then
                        brik_print "  [OK]      ${tool_name}"
                        passed=$((passed + 1))
                    else
                        brik_print "  [MISSING] ${tool_name}"
                        failed=$((failed + 1))
                    fi
                done
                ;;
            dotnet)
                if command -v dotnet >/dev/null 2>&1; then
                    brik_print "  [OK]      dotnet"
                    passed=$((passed + 1))
                else
                    brik_print "  [MISSING] dotnet"
                    failed=$((failed + 1))
                fi
                ;;
        esac
    else
        brik_print "  No stack detected in ${workspace}"
    fi

    # Summary
    brik_print ""
    brik_print "======================================"
    local summary="${passed} checks passed"
    if [[ "${failed}" -gt 0 ]]; then
        summary="${summary}, ${failed} missing"
    fi
    if [[ "${warned}" -gt 0 ]]; then
        summary="${summary}, ${warned} warnings"
    fi
    brik_print "${summary}"

    if [[ "${failed}" -gt 0 ]]; then
        return 1
    fi
    return "${EXIT_OK}"
}

# ---------------------------------------------------------------------------
# Command: init
# ---------------------------------------------------------------------------
cmd_init() {
    local stack=""
    local platform="gitlab"
    local target_dir="."
    local non_interactive=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --stack) stack="$2"; shift 2 ;;
            --platform) platform="$2"; shift 2 ;;
            --dir) target_dir="$2"; shift 2 ;;
            --non-interactive) non_interactive=true; shift ;;
            *) brik_error "unknown option: $1"; return "${EXIT_INVALID}" ;;
        esac
    done

    # Refuse to overwrite existing brik.yml
    if [[ -f "${target_dir}/brik.yml" ]]; then
        brik_error "brik.yml already exists in ${target_dir}"
        return "${EXIT_INVALID}"
    fi

    # Auto-detect stack if not specified
    if [[ -z "${stack}" ]]; then
        stack="$(_brik_detect_stack "${target_dir}")"
        if [[ "${stack}" == "unknown" ]]; then
            if [[ "${non_interactive}" == true ]]; then
                brik_error "could not detect stack and --stack was not specified"
                return "${EXIT_INVALID}"
            fi
            brik_error "could not detect stack - use --stack to specify one"
            return "${EXIT_INVALID}"
        fi
        brik_print "Detected stack: ${stack}"
    fi

    # Validate stack
    case "${stack}" in
        node|java|python|rust|dotnet) ;;
        *)
            brik_error "unsupported stack: ${stack}"
            brik_error "Supported stacks: node, java, python, rust, dotnet"
            return "${EXIT_INVALID}"
            ;;
    esac

    # Validate platform
    case "${platform}" in
        gitlab|github|jenkins) ;;
        *)
            brik_error "unsupported platform: ${platform}"
            brik_error "Supported platforms: gitlab, github, jenkins"
            return "${EXIT_INVALID}"
            ;;
    esac

    # Derive project name from directory
    local project_name
    project_name="$(basename "$(cd "${target_dir}" && pwd)")"

    # Generate brik.yml
    _brik_generate_config "${target_dir}" "${project_name}" "${stack}"

    # Generate platform bootstrap file
    _brik_generate_bootstrap "${target_dir}" "${platform}"

    brik_print "Created brik.yml and ${platform} bootstrap in ${target_dir}"
    return "${EXIT_OK}"
}

_brik_generate_config() {
    local target_dir="$1"
    local project_name="$2"
    local stack="$3"

    cat > "${target_dir}/brik.yml" <<YAML
version: 1

project:
  name: ${project_name}
  stack: ${stack}
YAML
}

_brik_generate_bootstrap() {
    local target_dir="$1"
    local platform="$2"

    case "${platform}" in
        gitlab)
            cat > "${target_dir}/.gitlab-ci.yml" <<'YAML'
include:
  - project: 'brik/gitlab-templates'
    ref: v0.1.0
    file: '/templates/pipeline.yml'
YAML
            ;;
        github)
            mkdir -p "${target_dir}/.github/workflows"
            cat > "${target_dir}/.github/workflows/ci.yml" <<'YAML'
name: Brik Pipeline
on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  brik:
    uses: getbrik/brik/.github/workflows/brik-pipeline.yml@v0.1.0
    with:
      config: brik.yml
YAML
            ;;
        jenkins)
            cat > "${target_dir}/Jenkinsfile" <<'GROOVY'
@Library('brik@v0.1.0') _
brikPipeline()
GROOVY
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Command: run stage
# ---------------------------------------------------------------------------
cmd_run() {
    if [[ $# -eq 0 ]]; then
        brik_error "'brik run' requires a subcommand. Usage: brik run stage <name>"
        return "${EXIT_INVALID}"
    fi

    local subcmd="$1"
    shift

    case "${subcmd}" in
        stage) cmd_run_stage "$@" ;;
        *)
            brik_error "unknown run subcommand: ${subcmd}"
            return "${EXIT_INVALID}"
            ;;
    esac
}

cmd_run_stage() {
    if [[ $# -eq 0 ]]; then
        brik_error "'brik run stage' requires a stage name"
        return "${EXIT_INVALID}"
    fi

    local stage_name="$1"
    shift
    local config_path="${DEFAULT_CONFIG}"
    local workspace
    workspace="$(pwd)"

    # Parse optional arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --config) config_path="$2"; shift 2 ;;
            --workspace) workspace="$2"; shift 2 ;;
            *) brik_error "unknown option: $1"; return "${EXIT_INVALID}" ;;
        esac
    done

    # Export environment for the runtime
    export BRIK_PROJECT_DIR="${workspace}"
    export BRIK_WORKSPACE="${workspace}"
    export BRIK_CONFIG_FILE="${config_path}"
    export BRIK_LOG_DIR="${BRIK_LOG_DIR:-/tmp/brik/logs}"

    # Load runtime (set +e to avoid conflict with runtime's no-set-e policy)
    # shellcheck source=../runtime/bash/lib/runtime/stage.sh
    . "${BRIK_HOME}/runtime/bash/lib/runtime/stage.sh"
    # shellcheck source=../runtime/bash/lib/core/_loader.sh
    . "${BRIK_HOME}/runtime/bash/lib/core/_loader.sh"

    # Map stage names to logic functions
    local logic_function=""
    case "${stage_name}" in
        build)
            brik.use build
            brik.use build.node 2>/dev/null || true
            logic_function="_brik_build_logic"
            ;;
        test)
            brik.use test
            logic_function="_brik_test_logic"
            ;;
        *)
            brik_error "unsupported stage: ${stage_name}"
            brik_error "Supported stages: build, test"
            return "${EXIT_INVALID}"
            ;;
    esac

    # Define logic wrapper functions
    # shellcheck disable=SC2329
    _brik_build_logic() {
        build.run "${BRIK_WORKSPACE}"
        return $?
    }

    # shellcheck disable=SC2329
    _brik_test_logic() {
        test.run "${BRIK_WORKSPACE}"
        return $?
    }

    # Disable set -e for stage.run (runtime does its own error handling)
    set +e
    stage.run "${stage_name}" "${logic_function}" "${workspace}" "${config_path}"
    local result=$?
    set -e

    return "${result}"
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------
main() {
    if [[ $# -eq 0 ]]; then
        cmd_help
        exit "${EXIT_OK}"
    fi

    local command="$1"
    shift

    case "${command}" in
        validate)
            cmd_validate "$@"
            exit "$?"
            ;;
        doctor)
            cmd_doctor "$@"
            exit "$?"
            ;;
        init)
            cmd_init "$@"
            exit "$?"
            ;;
        run)
            cmd_run "$@"
            exit "$?"
            ;;
        version)
            cmd_version
            exit "${EXIT_OK}"
            ;;
        help | --help | -h)
            cmd_help
            exit "${EXIT_OK}"
            ;;
        *)
            brik_error "unknown command: ${command}"
            brik_error "Run 'brik help' for usage."
            exit "${EXIT_INVALID}"
            ;;
    esac
}

main "$@"
